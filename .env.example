# Quorix Vietnam - AI providers configuration example
# Copy this file to .env and fill your real keys.

# Provider rotation order
# Valid providers: gemini, groq
AI_PROVIDER_ORDER=gemini,groq
AI_SEARCH_PROVIDER_ORDER=gemini,groq
AI_CHAT_PROVIDER_ORDER=gemini,groq

# Gemini keys (single or comma-separated list)
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_CHAT_API_KEY=
GEMINI_CHAT_API_KEYS=

# Gemini model selection
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Gemini token controls
GEMINI_MAX_OUTPUT_TOKENS=2200
GEMINI_SEARCH_MAX_OUTPUT_TOKENS=1200
GEMINI_CHAT_MAX_OUTPUT_TOKENS=2200

# Groq keys (single or comma-separated list)
GROQ_API_KEY=
GROQ_API_KEYS=

# Groq model selection
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_SEARCH_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Groq token controls
GROQ_MAX_TOKENS=2200
GROQ_SEARCH_MAX_TOKENS=1200
GROQ_CHAT_MAX_TOKENS=2200

# Chat continuation rounds when response is truncated
# Allowed range in code: 1..4
AI_CHAT_CONTINUE_STEPS=2
